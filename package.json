{
  "name": "discord-bot-v3",
  "version": "1.0.0",
  "description": "A clean Discord bot built with TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run clean && tsc",
    "start": "npm run build && node dist/index.js",
    "dev": "npm run build && node dist/index.js",
    "build:watch": "tsc --watch",
    "dev:watch": "concurrently -k \"npm run build:watch\" \"node --watch dist/index.js\"",
    "clean": "rimraf dist",
    "vps:start": "git pull && npm ci --no-fund && npm run build && pm2 start ecosystem.config.cjs",
    "vps:restart": "git pull && npm ci --no-fund && npm run build && pm2 restart discord_bot",
    "vps:logs": "pm2 logs discord_bot",
    "vps:stop": "pm2 delete discord_bot",
    "lint": "tsc --noEmit && npm run lint:eslint",
    "lint:eslint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:examples": "tsc --noEmit -p examples/tsconfig.json && eslint \"examples/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check:commands": "npx ts-node scripts/check-duplicate-commands.ts",
    "version:check": "npx ts-node scripts/version-check.ts"
  },
  "keywords": [
    "discord",
    "bot",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.5.0",
    "discord.js": "^14.25.1",
    "dotenv": "^16.3.1",
    "module-alias": "^2.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^4.0.18",
    "baseline-browser-mapping": "^2.10.35",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vitest": "^0.5.4",
    "prettier": "^3.7.4",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "diff": "4.0.4",
    "undici": "^6.23.0",
    "@typescript-eslint/utils": "^8.54.0"
  },
  "_moduleAliases": {
    "@commands": "dist/Commands",
    "@systems": "dist/Systems",
    "@middleware": "dist/Commands/Middleware",
    "@bot": "dist/Bot",
    "@database": "dist/Database",
    "@utilities": "dist/Utilities",
    "@shared": "dist/Shared",
    "@responders": "dist/Responders",
    "@events": "dist/Events",
    "@config": "dist/Config"
  }
}
