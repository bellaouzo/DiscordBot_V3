# Discord Bot V3 Environment Variables
# Copy this file to .env and fill in your values
# Never commit real keys or tokens to git.
# Use placeholder values only in this file.

# Required - Discord Bot Token
DISCORD_TOKEN=your_discord_bot_token_here

# Required - Discord Application Client ID
CLIENT_ID=your_client_id_here

# Required - Discord Guild ID (for command deployment)
GUILD_ID=your_guild_id_here

# Optional - Log level: debug | info | warn | error (default: info)
# LOG_LEVEL=info
# LOG_DEBUG=true

# Optional - Logging Channel Names (defaults shown)
# COMMAND_LOG_CHANNEL_NAME=command-logs
# COMMAND_LOG_CATEGORY_NAME=Bot Logs
# MESSAGE_DELETE_LOG_CHANNEL_NAME=deleted-logs
# DEPLOY_LOG_CHANNEL_NAME=deployment-logs

# Optional - OpenWeatherMap API Key for /weather command
# Get a free API key at https://openweathermap.org/api
# OPENWEATHER_API_KEY=your_api_key_here

# Optional - Additional third-party API keys
# API_APOD_KEY=your_nasa_api_key_here
# API_NEWS_KEY=your_newsapi_key_here
# API_TRANSLATE_KEY=your_translate_api_key_here

# Optional - API endpoint overrides and timeouts (milliseconds)
# API_APOD_URL=https://api.nasa.gov/planetary/apod
# API_NEWS_URL=https://newsapi.org/v2
# API_WEATHER_URL=https://api.openweathermap.org/data/2.5
# API_TRANSLATE_URL=https://api.mymemory.translated.net
# API_QUOTE_URL=https://zenquotes.io/api/random
# API_MEME_URL=https://meme-api.com/gimme
# API_JOKE_URL=https://v2.jokeapi.dev/joke
# API_DADJOKE_URL=https://icanhazdadjoke.com/
# API_FACT_URL=https://uselessfacts.jsph.pl/random.json
# API_TRIVIA_URL=https://opentdb.com/api.php
# API_INSULT_URL=https://evilinsult.com/generate_insult.php
# API_ROBLOX_BRIDGE_TIMEOUT_MS=8000

# Optional - Roblox Bridge Connection
# ROBLOX_BRIDGE_API_URL=https://your-domain.com
# ROBLOX_BRIDGE_API_KEY=your_bridge_api_secret_here
# ROBLOX_BRIDGE_URL_SIGNING_SECRET=your_url_signing_secret_here

# Optional - Strict startup (production-like): require all optional-feature API keys
# and Roblox URL signing when ROBLOX_BRIDGE_API_URL is set. Local dev should leave unset.
# BOT_STRICT_FEATURE_KEYS=1

# Optional but recommended hygiene guardrails
# APP_ENV_PATH should only point to local machine secrets, never a tracked file.
# DATA_DIR should point to a non-shared runtime directory for sqlite files.

# Optional - Persist command cooldowns across bot restarts (SQLite server.db)
# COOLDOWN_PERSIST=1

# Optional - App file and data locations
# APP_ENV_PATH=C:\path\to\.env
# DATA_DIR=C:\path\to\Discord_Bot_V3\data
