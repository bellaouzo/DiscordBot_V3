{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "rootDir": "..",
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "baseUrl": "../src",
    "paths": {
      "@commands": ["Commands/index"],
      "@commands/*": ["Commands/*"],
      "@systems": ["Systems"],
      "@systems/*": ["Systems/*"],
      "@middleware": ["Commands/Middleware/index"],
      "@middleware/*": ["Commands/Middleware/*"],
      "@bot": ["Bot/index"],
      "@bot/*": ["Bot/*"],
      "@database": ["Database/index"],
      "@database/*": ["Database/*"],
      "@utilities": ["Utilities/index"],
      "@utilities/*": ["Utilities/*"],
      "@shared": ["Shared/index"],
      "@shared/*": ["Shared/*"],
      "@responders": ["Responders/index"],
      "@responders/*": ["Responders/*"],
      "@events": ["Events/index"],
      "@events/*": ["Events/*"],
      "@config": ["Config/AppConfig"],
      "@config/*": ["Config/*"],
      "events": ["../node_modules/@types/node/events"]
    }
  },
  "include": ["./**/*.ts"]
}
